{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runx.ai/schemas/registry-binding.schema.json",
  "title": "runx upstream registry binding",
  "type": "object",
  "required": ["schema", "state", "skill", "upstream", "registry", "harness"],
  "properties": {
    "schema": {
      "const": "runx.registry_binding.v1"
    },
    "state": {
      "enum": ["registry_binding_drafted", "registry_bound", "harness_verified", "published"]
    },
    "skill": {
      "type": "object",
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "upstream": {
      "type": "object",
      "required": ["host", "owner", "repo", "path", "commit", "blob_sha", "source_of_truth"],
      "properties": {
        "host": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "blob_sha": {
          "type": "string"
        },
        "pr_url": {
          "type": "string"
        },
        "merged_at": {
          "type": "string"
        },
        "html_url": {
          "type": "string"
        },
        "raw_url": {
          "type": "string"
        },
        "source_of_truth": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "registry": {
      "type": "object",
      "required": ["owner", "trust_tier", "version", "profile_path", "materialized_package_is_registry_artifact"],
      "properties": {
        "owner": {
          "type": "string"
        },
        "trust_tier": {
          "enum": ["upstream-owned", "community", "unverified"]
        },
        "version": {
          "type": "string"
        },
        "install_command": {
          "type": "string"
        },
        "run_command": {
          "type": "string"
        },
        "profile_path": {
          "type": "string"
        },
        "materialized_package_is_registry_artifact": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "harness": {
      "type": "object",
      "required": ["status", "case_count"],
      "properties": {
        "status": {
          "enum": ["pending", "failed", "harness_verified"]
        },
        "case_count": {
          "type": "number"
        },
        "assertion_count": {
          "type": "number"
        },
        "case_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
