{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.runx.dev/runx/doctor/v1.json",
  "x-runx-schema": "runx.doctor.v1",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "schema",
    "status",
    "summary",
    "diagnostics"
  ],
  "properties": {
    "schema": {
      "const": "runx.doctor.v1",
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ]
    },
    "summary": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "errors",
        "warnings",
        "infos"
      ],
      "properties": {
        "errors": {
          "minimum": 0,
          "type": "integer"
        },
        "warnings": {
          "minimum": 0,
          "type": "integer"
        },
        "infos": {
          "minimum": 0,
          "type": "integer"
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "instance_id",
          "severity",
          "title",
          "message",
          "target",
          "location",
          "repairs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "instance_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "error",
              "warning",
              "info"
            ]
          },
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "target": {
            "type": "object",
            "additionalProperties": true
          },
          "location": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "json_pointer": {
                "type": "string"
              }
            }
          },
          "evidence": {
            "type": "object",
            "additionalProperties": true
          },
          "repairs": {
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "id",
                "kind",
                "confidence",
                "risk",
                "requires_human_review"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "create_file",
                    "replace_file",
                    "edit_yaml",
                    "edit_json",
                    "add_fixture",
                    "run_command",
                    "manual"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "risk": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high",
                    "sensitive"
                  ]
                },
                "path": {
                  "type": "string"
                },
                "json_pointer": {
                  "type": "string"
                },
                "contents": {
                  "type": "string"
                },
                "patch": {
                  "type": "string"
                },
                "command": {
                  "type": "string"
                },
                "requires_human_review": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}
